{
  "name": "base-front-spa",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "yarn vite && yarn generate:api",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "lint": "npm run eslint && npm run stylelint",
    "eslint": "eslint . --cache",
    "stylelint": "stylelint '**/*.css' --cache",
    "prettier": "prettier --check \"**/*.{ts,tsx}\"",
    "prettier:write": "prettier --write \"**/*.{ts,tsx}\"",
    "generate:api": "openapi-typescript https://api.mydevelopments.work/api-json -o src/services/schema/api-schema.ts"
  },
  "dependencies": {
    "@mantine/core": "^9.0.1",
    "@mantine/dates": "^9.0.2",
    "@mantine/hooks": "^9.0.1",
    "@mantine/modals": "^9.0.2",
    "@mantine/notifications": "^9.1.0",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-query-devtools": "^5.100.5",
    "dayjs": "^1.11.20",
    "i18next": "^25.10.9",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-icu": "^2.3.0",
    "intl-messageformat": "^11.2.1",
    "nuqs": "^2.8.9",
    "openapi-fetch": "^0.17.0",
    "openapi-react-query": "^0.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.6.6",
    "react-router-dom": "^7.9.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.37.0",
    "eslint-config-mantine": "^4.0.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^27.0.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.6",
    "postcss-preset-mantine": "1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.6.2",
    "stylelint": "^17.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "packageManager": "yarn@4.13.0"
}
